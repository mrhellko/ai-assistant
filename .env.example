POSTGRES_DB=assistant
POSTGRES_USER=assistant
POSTGRES_PASSWORD=assistant
DATABASE_URL=postgresql+asyncpg://assistant:assistant@postgres:5432/assistant

ASSISTANT_PUBLIC_BASE_URL=https://your-domain.example
ASSISTANT_SECRET=change-me
APP_TIMEZONE=Europe/Moscow

OPENAI_API_KEY=sk-change-me
